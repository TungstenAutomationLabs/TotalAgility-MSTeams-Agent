{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "resourceBaseName": {
      "value": "bot${{RESOURCE_SUFFIX}}"
    },
    "webAppSKU": {
      "value": "B1"
    },
    "botDisplayName": {
      "value": "TotalAgility Agent"
    },
    "totalAgilityEndpoint": {
      "value": "${{TOTALAGILITY_ENDPOINT}}"
    },
    "totalAgilityApiKey": {
      "value": "${{TOTALAGILITY_API_KEY}}"
    },
    "totalAgilityAgentName": {
      "value": "${{TOTALAGILITY_AGENT_NAME}}"
    },
    "totalAgilityAgentId": {
      "value": "${{TOTALAGILITY_AGENT_ID}}"
    }
    ,
    "totalAgilityTestUserName": {
      "value": "${{TOTALAGILITY_TEST_USERNAME}}"
    },
    "totalAgilityUseTestUser": {
      "value": "${{TOTALAGILITY_USE_TEST_USER}}"
    },
    "totalAgilityTemperature": {
      "value": "${{TOTALAGILITY_TEMPERATURE}}"
    },
    "totalAgilityUseSeed": {
      "value": "${{TOTALAGILITY_USE_SEED}}"
    },
    "totalAgilitySeed": {
      "value": "${{TOTALAGILITY_SEED}}"
    },
    "conversationHistoryMaxEntries": {
      "value": "${{CONVERSATION_HISTORY_MAX_ENTRIES}}"
    },
    "notificationsBearerToken": {
      "value": "${{NOTIFICATIONS_BEARER_TOKEN}}"
    }
  }
}