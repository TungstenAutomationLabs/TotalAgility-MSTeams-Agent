# This file includes environment variables that can be committed to git. It's gitignored by default because it represents your local development environment.

# Built-in environment variables
TEAMSFX_ENV=local
APP_NAME_SUFFIX=local

# Generated during provision, you can also add your own variables.
BOT_ID=
TEAMS_APP_ID=
BOT_DOMAIN=
BOT_ENDPOINT=

# For TotalAgility calls:
TOTALAGILITY_ENDPOINT=
SECRET_TOTALAGILITY_API_KEY=
TOTALAGILITY_AGENT_NAME=
SECRET_TOTALAGILITY_AGENT_ID=
TOTALAGILITY_TEST_USERNAME=
TOTALAGILITY_USE_TEST_USER=

# Optional LLM tuning parameters (defaults applied in code if unset)
TOTALAGILITY_TEMPERATURE=
TOTALAGILITY_USE_SEED=
TOTALAGILITY_SEED=

# Conversation history max entries (default: 10 if not set)
CONVERSATION_HISTORY_MAX_ENTRIES=

# Secrets — prefixed with SECRET_ so Teams Toolkit masks them in logs.
SECRET_NOTIFICATIONS_BEARER_TOKEN=
SECRET_AZURE_STORAGE_CONNECTION_STRING=

# Document preloading
PRELOAD_DOCUMENTS_AS_TOTALAGILITY_DOCS=
TOTALAGILITY_DOCUMENT_CREATOR_PROCESS_ID=
TOTALAGILITY_DOCUMENT_CREATOR_PROCESS_NAME=
